# Green Life Cannabis (greenlife-web) — env-var spec.
#
# Public marketing + customer-PWA site. Sister of seattle-cannabis-web with
# nearly-identical env shape. inventoryapp (admin/POS) lives in the sibling
# `Inventory App/` repo; cross-stack push integration via NEXT_PUBLIC_INVENTORYAPP_URL.
#
# Pattern:
#   - `NEXT_PUBLIC_*` exposed to client bundle (per-store branding, build SHA,
#     CAPTCHA site key, push public VAPID key, GA tag, feature flags)
#   - everything else is server-only (DB URL, secrets, private keys)
#
# Don't put secrets in `NEXT_PUBLIC_*`. Verify before commit.

# ── Database (required) ────────────────────────────────────────────────
# Postgres connection string. Production uses Vercel Neon integration which
# auto-injects POSTGRES_URL_NON_POOLING + POSTGRES_URL (set the same value
# under all 3 names locally for parity).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/greenlife
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# ── Site identity ──────────────────────────────────────────────────────
# Canonical origin (no trailing slash). Used for canonical link tags + OG +
# absolute URL building in emails. Vercel auto-injects VERCEL_URL but we
# prefer explicit production domain to avoid preview-URLs leaking into
# emails / sitemaps. Pre-prod previews fall through to VERCEL_URL.
NEXT_PUBLIC_SITE_URL=https://www.greenlifecannabis.com
NEXT_PUBLIC_SITE_ORIGIN=https://www.greenlifecannabis.com

# Build version label rendered in the footer for "did my push land" check.
# CI sets this from the package.json or commit count; locally falls through
# to "dev". Per memory feedback_empty_string_defense_use_or_not_nullish.
NEXT_PUBLIC_BUILD_VERSION=

# Vercel auto-injects VERCEL_GIT_COMMIT_SHA + the NEXT_PUBLIC_ mirror — both
# read by lib/version.ts to render short SHA in the footer next to BUILD_VERSION.
VERCEL_GIT_COMMIT_SHA=
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=

# ── Inventoryapp (cross-stack staff-app link) ─────────────────────────
# Used by the customer-PWA to link out to the staff-side from admin-only
# surfaces (Doug-in-customer-mode preview, etc.) AND by the cross-stack
# push helper (lib/push-via-inv) to POST to the inv /api/push/send endpoint.
NEXT_PUBLIC_INVENTORYAPP_URL=https://brapp.greenlifecannabis.com

# ── Cross-stack push (inv → glw subscribers) ──────────────────────────
# inv POSTs to glw's /api/push/send to push customer notifications (closure
# announcements, deal launches). glw's route validates this Bearer token
# (lib/auth.ts:verifyPushSendToken). MUST match PUSH_SEND_TOKEN on both sides.
PUSH_SEND_TOKEN=

# ── Web Push (VAPID keys for browser-push subscribers) ────────────────
# Generate via `npx web-push generate-vapid-keys`. Public key is exposed to
# the browser to register push subscriptions; private key signs outbound
# notifications server-side. VAPID_SUBJECT is a contact mailto: that browser
# push services (FCM/APNs/Mozilla) require for abuse-reporting.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:doug@seattlecannabis.co

# ── Resend (transactional email — order confirmations + welcomes) ─────
# Resend API key + per-store from-address + reply-to. RESEND_FROM should be
# from a verified domain (`noreply@send.greenlifecannabis.com` typical).
# RESEND_REPLY_TO routes customer replies to a monitored inbox (NOT info@
# which is unmonitored per memory project_info_email_unmonitored).
RESEND_API_KEY=
RESEND_FROM=noreply@send.greenlifecannabis.com
RESEND_REPLY_TO=

# ── Twilio (transactional SMS — order confirmations + opt-out STOP) ───
# Twilio Account SID + Auth Token + from-number (E.164 with leading +).
# Required for SMS opt-in flow + outbound order-ready texts.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Email/SMS feature gates (default OFF — flip per Vercel project) ───
# Both flags gate optional outbound channels. Default OFF so a fresh deploy
# can't accidentally email customers before Doug verifies the from-domain
# on Resend. Flip "true" only after deliverability is confirmed.
ORDER_CONFIRMATION_EMAIL_ENABLED=
WELCOME_EMAIL_ENABLED=

# ── Quiz nurture (D+0/D+3/D+7 follow-up email sequence) ───────────────
# Server-side gate at /api/quiz/capture; client-side mirror at
# NEXT_PUBLIC_QUIZ_NURTURE_ENABLED gates the form rendering. Both default OFF.
QUIZ_NURTURE_ENABLED=
NEXT_PUBLIC_QUIZ_NURTURE_ENABLED=

# ── Cloudflare Turnstile (CAPTCHA on public forms) ────────────────────
# Site key (public) for client-side widget; secret key (server-side) for
# token verification. Apply at https://dash.cloudflare.com/turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Google Analytics 4 ────────────────────────────────────────────────
# G-XXXXX measurement ID. Optional — pixel script gracefully degrades if unset.
NEXT_PUBLIC_GA_ID=

# ── Search-engine site verification (DNS or meta-tag alternates) ──────
# All optional. Set the value the search-engine console gives you; the
# meta tag injects on every page server-render.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_VERIFICATION=
